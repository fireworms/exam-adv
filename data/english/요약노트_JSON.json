  "top_15_traps": [
    {
      "id": 1,
      "trap": "양보 구문 반대 추론",
      "avoidance": "Despite/Although → 반대 의미 선지"
    },
    {
      "id": 2,
      "trap": "this/these로 시작하는 단락은 첫 번째 X",
      "avoidance": "글의 순서 (A)(B)(C) 중 지시어 시작은 절대 첫 번째 X"
    },
    {
      "id": 3,
      "trap": "However + 흐름 전환",
      "avoidance": "본문 방향이 바뀌는 자리 찾기"
    },
    {
      "id": 4,
      "trap": "시간 단위 환산",
      "avoidance": "72 hours = 3일, decade = 10년"
    },
    {
      "id": 5,
      "trap": "what vs that 혼동",
      "avoidance": "what=선행사 포함, that=선행사 필요"
    },
    {
      "id": 6,
      "trap": "제안동사 + that + 동사원형",
      "avoidance": "should 생략 시 동사원형 그대로"
    },
    {
      "id": 7,
      "trap": "'No prior experience' 직역 오류",
      "avoidance": "사전 경험 불필요 = 누구나 가능"
    },
    {
      "id": 8,
      "trap": "virtual vs visual 혼동",
      "avoidance": "virtual=가상, visual=시각"
    },
    {
      "id": 9,
      "trap": "이메일 칭찬 후 진짜 목적",
      "avoidance": "마지막 단락이 목적"
    },
    {
      "id": 10,
      "trap": "Apart from = ~을 제외하고",
      "avoidance": "except for와 동의"
    },
    {
      "id": 11,
      "trap": "공통지문 어휘 = 다의어",
      "avoidance": "학술적 의미로 출제 (assess=evaluate)"
    },
    {
      "id": 12,
      "trap": "배수 표현 어순",
      "avoidance": "배수 + as + 원급 + as"
    },
    {
      "id": 13,
      "trap": "가정법 혼합",
      "avoidance": "If 과거완료 + 주절 현재 영향"
    },
    {
      "id": 14,
      "trap": "어색한 문장이 사실 진술",
      "avoidance": "사실이라도 주제 이탈이면 정답"
    },
    {
      "id": 15,
      "trap": "No sooner ~ than 도치",
      "avoidance": "had + p.p. + than + 과거"
    }
  ],
