  "grammar_patterns": [
    {
      "id": 1,
      "name": "가정법 과거완료 + 도치",
      "form": "Had + S + p.p., S + would/could/might + have + p.p.",
      "equivalent": "If S had p.p., S would/could/might have p.p.",
      "example": "Had I realized what you were intending to do, I would have stopped you.",
      "korean": "내가 알아챘다면 막았을 텐데.",
      "appeared_in": "2022 지방직 6번"
    },
    {
      "id": 2,
      "name": "제안·요구·명령 + that + S + (should) + 동사원형",
      "verbs": [
        "suggest",
        "recommend",
        "demand",
        "insist",
        "propose",
        "require",
        "request",
        "order"
      ],
      "example": "The broker recommended that she buy the stocks immediately.",
      "key_point": "should 생략되면 동사원형 그대로",
      "appeared_in": "2023 국가직 6번",
      "form": "동사(suggest/recommend/demand/insist/propose/require/request/order) + that + S + (should) + 동사원형",
      "korean": "중개인은 그녀가 즉시 주식을 살 것을 권고했다."
    },
    {
      "id": 3,
      "name": "이성적 판단 형용사 + that + S + (should) + 동사원형",
      "adjectives": [
        "essential",
        "important",
        "necessary",
        "vital",
        "imperative",
        "crucial"
      ],
      "example": "It is essential that every citizen be aware of the changes.",
      "key_point": "동사 패턴과 동일하게 should 생략 가능",
      "form": "It is 형용사(essential/important/necessary/vital/imperative/crucial) + that + S + (should) + 동사원형",
      "korean": "모든 시민이 변화를 인식하는 것이 필수적이다."
    },
    {
      "id": 4,
      "name": "부정어구 도치",
      "patterns": [
        "Hardly/Scarcely had + S + p.p. + when/before + S + 과거",
        "No sooner had + S + p.p. + than + S + 과거",
        "Not until + 부사구 + did + S + V",
        "Never have + S + p.p."
      ],
      "example": "Hardly had I closed my eyes when I began to think of her.",
      "appeared_in": "2023 국가직 6번",
      "form": "Hardly/Scarcely had + S + p.p. + when/before + S + 과거\nNo sooner had + S + p.p. + than + S + 과거\nNot until + 절/구 + did + S + V\nNever/Seldom + have + S + p.p.",
      "korean": "눈을 감자마자 그녀 생각이 나기 시작했다."
    },
    {
      "id": 5,
      "name": "분사구문 (Being 생략)",
      "form": "(Being) p.p. ~, S + V",
      "example": "(Being) Confronted with difficulties, he didn't give up.",
      "equivalent": "As/Since he was confronted with difficulties...",
      "korean": "어려움에 직면했지만, 그는 포기하지 않았다."
    },
    {
      "id": 6,
      "name": "with + 명사 + 분사 부대상황",
      "form": "with + N + 현재분사/과거분사",
      "examples": [
        "with the legs crossed (다리를 꼰 채)",
        "with everything considered (모든 것을 고려하면)"
      ],
      "appeared_in": "2022 국가직 14번",
      "example": "with the legs crossed / with everything considered",
      "korean": "다리를 꼰 채로 앉아 있었다. / 모든 것을 고려하면."
    },
    {
      "id": 7,
      "name": "관계대명사 what vs that",
      "rule": {
        "what": "선행사 포함 (the thing which) - 명사절 형성",
        "that": "선행사 필요 - 형용사절 형성"
      },
      "exam_trick": "students [what→who] get adequate sleep (선행사 students 있으니 who/that)",
      "form": "what: 선행사 포함 (= the thing which) → 명사절\nthat: 선행사 필요 → 형용사절 (선행사 있으면 who/that, 없으면 what)",
      "example": "I know what she means. / The book that I read was interesting.",
      "korean": "그녀가 의미하는 것을 안다. / 내가 읽은 책은 흥미로웠다."
    },
    {
      "id": 8,
      "name": "5형식 동사 + 목적어 + to부정사",
      "verbs": [
        "require",
        "ask",
        "expect",
        "want",
        "allow",
        "enable",
        "encourage",
        "remind",
        "advise",
        "tell"
      ],
      "example": "Companies required all employees to work from physical offices.",
      "key_point": "사역동사(make/have/let)는 동사원형, 지각동사는 원형/-ing",
      "form": "동사(require/ask/expect/want/allow/enable/encourage/remind/advise/tell) + 목적어 + to부정사\n※ 사역동사(make/have/let) → 동사원형 / 지각동사 → 원형 또는 -ing",
      "korean": "회사는 모든 직원들이 사무실에서 근무하도록 요구했다."
    },
    {
      "id": 9,
      "name": "배수 표현",
      "form": "배수 + as + 원급 + as",
      "examples": [
        "twice as expensive as",
        "three times as old as"
      ],
      "appeared_in": "2024 지방직 7번",
      "example": "This car is twice as expensive as that one.",
      "korean": "이 차는 저 차보다 두 배 비싸다."
    },
    {
      "id": 10,
      "name": "cannot + V too much (강조)",
      "form": "cannot + 동사 + too + 부사/형용사 = 아무리 ~해도 지나치지 않다",
      "example": "Children cannot be too careful when crossing the street.",
      "appeared_in": "2022 국가직 13번",
      "korean": "어린이들은 길을 건널 때 아무리 조심해도 지나치지 않다."
    }
  ],
